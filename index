            background-size: cover;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: white;
            position: relative;
            padding: 40px 20px;
        }

        .hero-content {
            position: relative;
            z-index: 1;
            padding: 20px;
        }

        .hero h1 {
            font-size: 2rem;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }

        .hero h2 {
            font-size: 1.6rem;
            margin-bottom: 10px;
        }

        .hero p {
            font-size: 1.2rem;
            margin-bottom: 10px;
        }

        /* Стили для обратного отсчёта — читаемый даже на светлом фоне */
        .countdown {
            font-size: 1.5rem;
            font-weight: bold;
            margin-top: 20px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
            background: rgba(0,0,0,0.6);
            padding: 10px 20px;
            border-radius: 50px;
            display: inline-block;
            backdrop-filter: blur(4px);
        }

        /* Остальные блоки */
        .message {
            padding: 40px 20px;
            max-width: 800px;
            margin: 0 auto;
            text-align: center;
        }

        .couple-photo {
            max-width: 100%;
            height: auto;
            border-radius: 10px;
            margin-bottom: 30px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

        .message h2, .schedule h2, .location h2, .color-palette h2 {
            font-size: 1.8rem;
            margin-bottom: 20px;
            color: #8b4513;
        }

        .message p {
